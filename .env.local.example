# Supabase project URL. Public; referenced as NEXT_PUBLIC_ so it ships to the browser.
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon (publishable) key. Safe to expose; all access is RLS-enforced.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key. Bypasses RLS — SERVER ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic Claude API key. Powers reasoning, hints, and coach features. Server only.
ANTHROPIC_API_KEY=

# Razorpay key ID. Public identifier used when creating orders/subscriptions.
RAZORPAY_KEY_ID=

# Razorpay secret. Server only; used to sign orders and verify webhook signatures.
RAZORPAY_KEY_SECRET=

# Resend API key. Transactional email delivery (auth, receipts, reminders). Server only.
RESEND_API_KEY=

# Upstash Redis REST URL. Backs rate limiting and short-lived caches (e.g. daily challenge).
UPSTASH_REDIS_REST_URL=

# Upstash Redis REST token. Paired with the URL above. Server only.
UPSTASH_REDIS_REST_TOKEN=
